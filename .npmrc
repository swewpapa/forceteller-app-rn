# React Native tooling (Metro, autolinking, CocoaPods) does not work with
# pnpm's default symlinked node_modules. The hoisted linker creates a flat
# node_modules like npm/Yarn Classic. See https://pnpm.io/settings#nodelinker
node-linker=hoisted

# Font Awesome Pro (scoped registry). The auth token is NOT stored here — it
# comes from each developer's global ~/.npmrc (//npm.fontawesome.com/:_authToken).
# Get a token at https://fontawesome.com/account → "Tokens".
@fortawesome:registry=https://npm.fontawesome.com/
